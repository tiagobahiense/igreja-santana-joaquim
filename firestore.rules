rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ────────────────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    function isManager() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin != true;
    }

    function canAccessChurch(churchId) {
      return isAdmin() ||
        (isManager() && exists(/databases/$(database)/documents/churches/$(churchId)));
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // ─── Users ──────────────────────────────────────────────────────────────────
    match /users/{uid} {
      allow read: if isSignedIn();
      allow create: if isAdmin();
      allow update: if isAdmin() || (
        isOwner(uid) &&
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['isAdmin', 'churchIds', 'email'])
      );
      allow delete: if isAdmin();
    }

    // ─── Churches ───────────────────────────────────────────────────────────────
    match /churches/{churchId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ─── Tithes (donors) ────────────────────────────────────────────────────────
    match /tithes/{tithesId} {
      allow read: if isAdmin() || canAccessChurch(resource.data.churchId);
      allow create: if !isAdmin() && canAccessChurch(request.resource.data.churchId);
      allow update: if !isAdmin() && canAccessChurch(resource.data.churchId);
      allow delete: if !isAdmin() && canAccessChurch(resource.data.churchId);

      // Donations subcollection
      match /donations/{year} {
        allow read: if isAdmin() || canAccessChurch(get(/databases/$(database)/documents/tithes/$(tithesId)).data.churchId);
        allow write: if !isAdmin() && canAccessChurch(get(/databases/$(database)/documents/tithes/$(tithesId)).data.churchId);
      }
    }

    // ─── Expenses ───────────────────────────────────────────────────────────────
    match /expenses/{expenseId} {
      allow read: if isAdmin() || canAccessChurch(resource.data.churchId);
      allow create: if !isAdmin() && canAccessChurch(request.resource.data.churchId);
      allow update: if !isAdmin() && canAccessChurch(resource.data.churchId);
      allow delete: if !isAdmin() && canAccessChurch(resource.data.churchId);
    }

    // ─── Tasks (personal) ───────────────────────────────────────────────────────
    match /tasks/{taskId} {
      allow read: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow delete: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
    }

    // ─── Settings ───────────────────────────────────────────────────────────────
    match /settings/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ─── Summaries ──────────────────────────────────────────────────────────────
    match /summaries/{summaryId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // ─── Audit Logs ─────────────────────────────────────────────────────────────
    match /logs/{logId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    // ─── Parish events (agenda da matriz) ───────────────────────────────────────
    match /events/{eventId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isSignedIn() && !isAdmin();
    }
  }
}
