# Copie para .env.local e preencha com os valores do Firebase Console.
# No Cloudflare Pages, configure as mesmas variáveis VITE_* em Settings → Environment variables.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Apenas para scripts locais (seed:admin, repair:manager)
FIREBASE_ADMIN_EMAIL=
FIREBASE_ADMIN_PASSWORD=
